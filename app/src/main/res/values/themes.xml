<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme — Compose manages everything, this just disables legacy ActionBar -->
    <style name="Theme.DotsAndBoxes" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="postSplashScreenTheme">@style/Theme.DotsAndBoxes.Main</item>
    </style>

    <style name="Theme.DotsAndBoxes.Main" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
